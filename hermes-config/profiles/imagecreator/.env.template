# Imagecreator Hermes Profile — Environment Reference
# NOTE: This .env is for Hermes profile reference only.
# The tg_bot.py process has its token hardcoded and does NOT read from here.
# Do NOT start a Hermes gateway for this profile — imagecreator runs its own Telegram polling loop.

# Bot token (reference copy — authoritative source is hardcoded in bin/tg_bot.py)
IMAGECREATOR_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Secondary token used by send_photo.sh/send_video.sh/send_text.sh
IMAGECREATOR_SEND_TOKEN=YOUR_SEND_TOKEN_HERE

# Telegram user (owner)
TELEGRAM_ALLOWED_USERS=YOUR_TELEGRAM_USER_ID

# Workspace
IMAGECREATOR_WORKSPACE=/path/to/your/imagecreator-workspace

# ComfyUI
COMFYUI_BASE=http://127.0.0.1:8000
COMFYUI_VENV=/path/to/your/comfyui/.venv
COMFYUI_BASE_DIR=/path/to/your/comfyui
