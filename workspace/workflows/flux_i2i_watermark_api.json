{
  "_comment": "Watermark removal: VAEEncode (i2i at 45% noise) + ControlNet Canny (strong edges only, preserves structure) + XlabsSampler. Watermark text is high-frequency detail destroyed by partial noise; main content survives.",
  "_models": [
    "unet/flux1-dev.safetensors",
    "clip/clip_l.safetensors + t5xxl_fp8_e4m3fn.safetensors",
    "vae/ae.safetensors",
    "xlabs/controlnets/flux-canny-controlnet-v3.safetensors"
  ],
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "LoadFluxControlNet",
    "inputs": {
      "model_name": "flux-dev",
      "controlnet_path": "flux-canny-controlnet-v3.safetensors"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.jpg"
    }
  },
  "6": {
    "class_type": "ImageScale",
    "inputs": {
      "image": [
        "5",
        0
      ],
      "upscale_method": "lanczos",
      "width": 1024,
      "height": 1024,
      "crop": "center"
    }
  },
  "7": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "6",
        0
      ],
      "vae": [
        "3",
        0
      ]
    }
  },
  "8": {
    "class_type": "Canny",
    "inputs": {
      "image": [
        "6",
        0
      ],
      "low_threshold": 0.3,
      "high_threshold": 0.6
    }
  },
  "9": {
    "class_type": "ApplyFluxControlNet",
    "inputs": {
      "controlnet": [
        "4",
        0
      ],
      "image": [
        "8",
        0
      ],
      "strength": 0.35
    }
  },
  "10": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "clip_l": "clean image, no watermark, no text overlay, no logo, no signature, high quality, detailed",
      "t5xxl": "clean image, no watermark, no text overlay, no logo, no signature, high quality, detailed",
      "guidance": 3.5
    }
  },
  "11": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "clip_l": "NEGATIVE: watermark, text, logo, signature, overlay, stamp, inscription, low quality, blurry",
      "t5xxl": "NEGATIVE: watermark, text, logo, signature, overlay, stamp, inscription, low quality, blurry",
      "guidance": 3.5
    }
  },
  "12": {
    "class_type": "XlabsSampler",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "conditioning": [
        "10",
        0
      ],
      "neg_conditioning": [
        "11",
        0
      ],
      "noise_seed": 42,
      "steps": 25,
      "timestep_to_start_cfg": 1,
      "true_gs": 3.5,
      "image_to_image_strength": 0.45,
      "denoise_strength": 1.0,
      "latent_image": [
        "7",
        0
      ],
      "controlnet_condition": [
        "9",
        0
      ]
    }
  },
  "13": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "12",
        0
      ],
      "vae": [
        "3",
        0
      ]
    }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {
      "images": [
        "13",
        0
      ],
      "filename_prefix": "flux_watermark"
    }
  }
}