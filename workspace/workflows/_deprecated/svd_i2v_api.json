{
  "_comment": "SVD (Stable Video Diffusion) image-to-video. Animates a single image into 25-frame video. No text prompt — purely image-driven motion. Requires svd_xt.safetensors in checkpoints/.",
  "1": {
    "class_type": "ImageOnlyCheckpointLoader",
    "inputs": {
      "ckpt_name": "svd_xt.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.jpg"
    }
  },
  "3": {
    "class_type": "VideoLinearCFGGuidance",
    "inputs": {
      "model": ["1", 0],
      "min_cfg": 1.0
    }
  },
  "4": {
    "class_type": "SVD_img2vid_Conditioning",
    "inputs": {
      "clip_vision": ["1", 1],
      "init_image": ["2", 0],
      "vae": ["1", 2],
      "width": 1024,
      "height": 576,
      "video_frames": 25,
      "motion_bucket_id": 40,
      "fps": 8,
      "augmentation_level": 0.05
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0],
      "positive": ["4", 0],
      "negative": ["4", 1],
      "latent_image": ["4", 2],
      "seed": 42,
      "steps": 20,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["6", 0],
      "frame_rate": 8,
      "loop_count": 0,
      "filename_prefix": "svd_i2v",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "trim_to_audio": false,
      "pingpong": false,
      "save_output": true
    }
  }
}
