{
  "_comment": "IP-Adapter t2i LoRA: face reference via IP-Adapter (ip_scale=0.35) + LoRA + EmptyLatentImage (pure generation, no i2i anchor, no ControlNet). Use for content-transforming LoRAs (R18, costume change, pose). ip_scale injected at runtime via inject_params.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "default"
    }
  },
  "17": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "手办制造.safetensors",
      "strength_model": 0.85
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "LoadFluxIPAdapter",
    "inputs": {
      "ipadatper": "ip_adapter.safetensors",
      "clip_vision": "clip_vision_l.safetensors",
      "provider": "CPU"
    }
  },
  "6": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.jpg"
    }
  },
  "7": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["6", 0],
      "upscale_method": "lanczos",
      "width": 1024,
      "height": 1024,
      "crop": "center"
    }
  },
  "8": {
    "class_type": "ApplyFluxIPAdapter",
    "inputs": {
      "model": ["17", 0],
      "ip_adapter_flux": ["4", 0],
      "image": ["7", 0],
      "ip_scale": 0.35
    }
  },
  "11": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "beautiful female character, high quality, detailed, masterpiece",
      "t5xxl": "beautiful female character, high quality, detailed, masterpiece",
      "guidance": 3.5
    }
  },
  "12": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "NEGATIVE: blurry, bad anatomy, deformed, watermark, low quality, ugly, mutilated",
      "t5xxl": "NEGATIVE: blurry, bad anatomy, deformed, watermark, low quality, ugly, mutilated",
      "guidance": 3.5
    }
  },
  "19": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "14": {
    "class_type": "XlabsSampler",
    "inputs": {
      "model": ["8", 0],
      "conditioning": ["11", 0],
      "neg_conditioning": ["12", 0],
      "noise_seed": 42,
      "steps": 28,
      "timestep_to_start_cfg": 1,
      "true_gs": 3.5,
      "image_to_image_strength": 1.0,
      "denoise_strength": 1.0,
      "latent_image": ["19", 0]
    }
  },
  "15": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["14", 0],
      "vae": ["3", 0]
    }
  },
  "16": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["15", 0],
      "filename_prefix": "flux_ip_t2i_lora"
    }
  }
}
