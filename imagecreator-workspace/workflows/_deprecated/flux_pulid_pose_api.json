{
  "_comment": "正式路线A — PuLID身份锁定 + DWPose姿势迁移: PuLID-Flux(A face, weight=0.9) + DWPose→Union ControlNet OpenPose(B pose, strength=0.6) + EmptyLatent. 原生SamplerCustomAdvanced采样.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "t5xxl_fp8_e4m3fn.safetensors",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "10": {
    "class_type": "PulidFluxModelLoader",
    "inputs": {
      "pulid_file": "pulid_flux_v0.9.1.safetensors"
    }
  },
  "11": {
    "class_type": "PulidFluxInsightFaceLoader",
    "inputs": {
      "provider": "CPU"
    }
  },
  "12": {
    "class_type": "PulidFluxEvaClipLoader",
    "inputs": {}
  },
  "20": {
    "class_type": "LoadImage",
    "_meta": { "title": "A角色参考图 (face)" },
    "inputs": {
      "image": "FACE_IMAGE_PLACEHOLDER"
    }
  },
  "21": {
    "class_type": "ApplyPulidFlux",
    "inputs": {
      "model": ["1", 0],
      "pulid_flux": ["10", 0],
      "eva_clip": ["12", 0],
      "face_analysis": ["11", 0],
      "image": ["20", 0],
      "weight": 0.9,
      "start_at": 0.0,
      "end_at": 1.0
    }
  },
  "30": {
    "class_type": "LoadImage",
    "_meta": { "title": "B姿势参考图 (pose)" },
    "inputs": {
      "image": "BODY_IMAGE_PLACEHOLDER"
    }
  },
  "31": {
    "class_type": "DWPreprocessor",
    "inputs": {
      "image": ["30", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024,
      "bbox_detector": "yolox_l.onnx",
      "pose_estimator": "dw-ll_ucoco_384.onnx",
      "scale_stick_for_xinsr_cn": "disable"
    }
  },
  "32": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "flux-union-pro/diffusion_pytorch_model.safetensors"
    }
  },
  "33": {
    "class_type": "SetUnionControlNetType",
    "inputs": {
      "control_net": ["32", 0],
      "type": "openpose"
    }
  },
  "40": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "same character, same identity, high quality, detailed, masterpiece"
    }
  },
  "41": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["40", 0],
      "guidance": 3.5
    }
  },
  "42": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["41", 0],
      "negative": ["41", 0],
      "control_net": ["33", 0],
      "image": ["31", 0],
      "strength": 0.6,
      "start_percent": 0.0,
      "end_percent": 0.8
    }
  },
  "50": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": ["21", 0],
      "conditioning": ["42", 0]
    }
  },
  "51": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 42
    }
  },
  "52": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "53": {
    "class_type": "BasicScheduler",
    "inputs": {
      "model": ["21", 0],
      "scheduler": "simple",
      "steps": 20,
      "denoise": 1.0
    }
  },
  "54": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    }
  },
  "55": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["51", 0],
      "guider": ["50", 0],
      "sampler": ["52", 0],
      "sigmas": ["53", 0],
      "latent_image": ["54", 0]
    }
  },
  "60": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["55", 0],
      "vae": ["3", 0]
    }
  },
  "61": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["60", 0],
      "filename_prefix": "flux_pulid_pose"
    }
  }
}
