# ============================================
# ComfyGram - Telegram Bot for ComfyUI
# Environment Variables Configuration
# ============================================

# -------------------------------
# Telegram Configuration
# -------------------------------
# Get your bot token from @BotFather on Telegram
IMAGECREATOR_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Separate token for send operations
IMAGECREATOR_SEND_TOKEN=your_send_token_here

# Your Telegram User ID (get from @userinfobot)
# Only this user can interact with the bot
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# -------------------------------
# Directory Configuration
# -------------------------------
# Workspace directory (where tasks, results, and logs are stored)
IMAGECREATOR_WORKSPACE=$HOME/imagecreator-workspace

# ComfyUI installation directory
COMFYUI_BASE_DIR=$HOME/ComfyUI

# ComfyUI API endpoint
COMFYUI_BASE=http://127.0.0.1:8000

# -------------------------------
# Optional: Advanced Configuration
# -------------------------------
# Python virtual environment for ComfyUI
# COMFYUI_VENV=$COMFYUI_BASE_DIR/.venv

# Custom ComfyUI input/output directories
# COMFYUI_INPUT=$COMFYUI_BASE_DIR/input
# COMFYUI_OUTPUT=$COMFYUI_BASE_DIR/output
